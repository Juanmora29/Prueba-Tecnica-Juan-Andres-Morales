# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Embeddings (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.4

# ChromaDB
CHROMA_DB_PATH=./chroma_db

# Docs
DOCS_DIR=./docs

# Server
HOST=0.0.0.0
PORT=8000
